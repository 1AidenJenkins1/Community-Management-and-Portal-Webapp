/**
 * This is just used to display the version history easily i will add JSDoc for this func later
 */
function createVersionHistoryElement_(Args = {}) {
  const {
    versionId,
    releaseDate,
    description,
  } = Args;
  return VersionHistoryElement = 
  {
    type: UIElementType.CONTAINER, id:`version-history-${versionId}-textBox`,
    Access:{ permission: PERMISSION.ALL, rankList:[ RANK.ALL ], divisionList:[ RANK.ALL ] } ,
    content: [
      { 
        type: UIElementType.TEXT, textType: TextType.H1, id: "Version-Header", 
        Access:{ permission: PERMISSION.ALL, rankList:[ RANK.ALL ], divisionList:[ RANK.ALL ] },
        content: versionId, 
      },
      { 
        type: UIElementType.TEXT, textType: TextType.H3, id: "Version-date", 
        Access:{ permission: PERMISSION.ALL, rankList:[ RANK.ALL ], divisionList:[ RANK.ALL ] },
        content: releaseDate, 
      },
      { 
        type: UIElementType.TEXT, textType: TextType.P, id: "Version-description", 
        Access:{ permission: PERMISSION.ALL, rankList:[ RANK.ALL ], divisionList:[ RANK.ALL ] },
        content: description, 
      }
    ]
  }
}

