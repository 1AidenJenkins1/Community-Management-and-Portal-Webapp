   * - Optional
   * - Compatable with column argument
   * - ⚠️ Conflicts with formattedRange argument ⚠️
   * - ⚠️ Conflicts with range argument ⚠️
  */
  /**
   * **Documentation:** 
   * - https://developers.google.com/workspace/add-ons/guides/connect-third-party-service
   * - https://developers.google.com/workspace/sheets/api/guides/concepts
   * - https://github.com/googlesamples/apps-script-oauth2#1-create-the-oauth2-service
   * 
   * Uses service account API to write data onto a google sheet then caches the sheet.
   * - **Version:** *PRE-ALPHA 1.02.02 (12/2/2025)*
   * - **File:** GS-API-OAuth2-Service-Account-GoogleSheets.gs
   * - **Section:** EDIT SHEET DATA
   * - **Member Of:** SheetServiceAPI
   *  
   * @param {Args_OAuth2_SheetServiceAPI_writeData} Args 
   * The config arguments for the write function
   * 
   * Required Arguments:
   * - sheetName
   * - spreadsheetId
   * - content
   * 
   * Optional Arguments:
   * - formattedRange
   * - range
   * - column
   * - row
   * 
   * @return {boolean} 
   * If the API write call succeeded.
   * 
   * @public
  */
  static writeData(Args) {
    let {
      spreadsheetId,
      sheetName,
      content,
      formattedRange,
      range,
      column,
      row,
    } = Args;

    // if no formatted range provided use args to get formatted range 
    if (!formattedRange) {
      formattedRange = this.formatRange(Args);
    }
    // give warning that without defined range the service account will default write into cell A1
    if (!formattedRange.includes("!")) {
      console.warn(
        `(Service Account) Initializing data write onto sheet (${sheetName}), in range ${formattedRange}, from spreadsheet (${spreadsheetId});` + `\n` + 
        `No range argument passed;` + `\n` +
        `Service account API will default write onto cell A1;`
      ); 
    }

    const service = this.getService();

    // ensure the service account has access
    if (!service.hasAccess()) {
      console.error(
        `\n` + 
        `(Service Account) Cannot attempt to write data onto sheet (${sheetName}), in range ${formattedRange}, from spreadsheet (${spreadsheetId});` + `\n` + 
        `Failure to get valid access token;` 
      ); 
      return false;
    }

    // format the write call
    const data = {
      values: content,
    }

    const accessToken = service.getAccessToken();
    const apiUrl = `https://sheets.googleapis.com/v4/spreadsheets/${spreadsheetId}/values/${formattedRange}?valueInputOption=USER_ENTERED`;
    const options = {
      method: 'put',
      muteHttpExceptions: true, // Prevents script from stopping on 400/500 errors
      headers: {
        'Authorization': 'Bearer ' + accessToken,
        'Content-Type': 'application/json',
      },
      payload: JSON.stringify(data)
    };

    try {
      // send write call and store response
      const response = UrlFetchApp.fetch(apiUrl, options);
      const responseCode = response.getResponseCode();

      // code 200 means success
      if (responseCode === 200) {

        this.cacheData({
          sheetName,
          spreadsheetId,
        });

        return true;
      } else {
        // send error if the call failed
        const errorText = response.getContentText();
        console.error(
          `\n` + 
          `(Service Account) Attempting to write data onto sheet (${sheetName}), in range ${formattedRange}, from spreadsheet (${spreadsheetId});` + `\n` + 
          `API write data failure (${responseCode});` + `\n` +
          `${errorText}`
        ); 
        return false;
      }
    } catch (error) {
      // send error if attemping to send call failed
      console.error(
        `\n` + 
        `(Service Account) Attempting to write data onto sheet (${sheetName}), in range ${formattedRange}, from spreadsheet (${spreadsheetId});` + `\n` + 
        `URL write failure;` + `\n` +
        `${error.toString()}`
      );
      return false;
    }
  }

  /** 
   * @typedef {object} Args_OAuth2_SheetServiceAPI_appendData
   *
   * @property {string} sheetName
   * The name of the sheet from the spreadsheet.
   * - Required
   * 
   * @property {string} spreadsheetId
   * The id of the spreadsheet containing the sheet.
   * - Required
   * 
   * @property {Array<Array<any>>} content
   * Data you are appending onto the sheet. 
   * - Required
   * - 2D array 
  */
  /**
   * **Documentation:** 
   * - https://developers.google.com/workspace/add-ons/guides/connect-third-party-service
   * - https://developers.google.com/workspace/sheets/api/guides/concepts
   * - https://github.com/googlesamples/apps-script-oauth2#1-create-the-oauth2-service
   * 
   * Uses service account API to append data onto the end of a google sheet then caches the sheet.
   * - **Version:** *PRE-ALPHA 1.02.04 (1/12/2026)*
   * - **File:** GS-API-OAuth2-Service-Account-GoogleSheets.gs
   * - **Section:** EDIT SHEET DATA
   * - **Member Of:** SheetServiceAPI
   *  
   * @param {Args_OAuth2_SheetServiceAPI_appendData} Args 
   * The config arguments for the append function
   * 
   * Required Arguments:
   * - sheetName
   * - spreadsheetId
   * - content
   * 
   * @return {boolean} 
   * If the API append call succeeded.
   * 
   * @public
  */
  static appendData(Args) {
    let { 
      spreadsheetId,
      sheetName, 
      content 
    } = Args;

    // if no spreadsheet id or invalid spreadsheet id provided, warn 
    if (typeof spreadsheetId !== `string`) { 
      throw new Error(
        `\n` + 
        `(Service Account) Cannot attempt to append rows onto sheet;` + `\n` +
        `No spreadsheet ID argument provided;` 
      );
    };

    // if no sheet name or invalid sheet name provided, throw error
    if (typeof sheetName !== `string`) { 
      throw new Error(
        `\n` + 
        `(Service Account) Cannot attempt to append rows onto sheet, from spreadsheet (${spreadsheetId});` + `\n` +
        `No sheet name argument provided;` 
      );
    };

    const service = this.getService();
    if (!service.hasAccess()) {
      console.error(
        `\n` + 
        `(Service Account) Cannot attempt to append rows onto sheet (${sheetId}), from spreadsheet (${spreadsheetId});` + `\n` + 
        `Failure to get valid access token;` 
      ); 
      return false;
    }

    const accessToken = service.getAccessToken();
    // Tells the API the sheet to append to 
    const apiUrl = `https://sheets.googleapis.com/v4/spreadsheets/${spreadsheetId}/values/${encodeURIComponent(sheetName)}:append?valueInputOption=USER_ENTERED`;    

    // format append call
    const data = { 
      values: content 
    };

    const options = {
      method: 'post',
      muteHttpExceptions: true,
      headers: {
        'Authorization': 'Bearer ' + accessToken,
        'Content-Type': 'application/json',
      },
      payload: JSON.stringify(data)
    };

     try {
      // send append call and store response
      const response = UrlFetchApp.fetch(apiUrl, options);
      const responseCode = response.getResponseCode();

      // code 200 means success
      if (responseCode === 200) {

        this.cacheData({
          sheetName,
          spreadsheetId,
        });

        return true;
      } else {
        // send error if the call failed
        const errorText = response.getContentText();
        console.error(
          `\n` + 
          `(Service Account) Attempting to append data onto sheet (${sheetName}), from spreadsheet (${spreadsheetId});` + `\n` + 
          `API append data failure (${responseCode});` + `\n` +
          `${errorText}`
        ); 
        return false;
      }
    } catch (error) {
      // send error if attemping to send call failed
      console.error(
        `\n` + 
        `(Service Account) Attempting to append data onto sheet (${sheetName}), in range ${formattedRange}, from spreadsheet (${spreadsheetId});` + `\n` + 
        `URL append data failure;` + `\n` +
        `${error.toString()}`
      );
      return false;
    }
  }

  /** 
   * @typedef {object} Args_OAuth2_SheetServiceAPI_deleteRows
   *
   * @property {Enum_serviceAccountAPI_Spreadsheet_MemberType_Sheet} sheet
   * The sheet object containing the data of the sheet from the spreadsheet.
   * - Required
   * - Spreadsheet.[target spreadsheet].sheet.[target sheet]
   *
   * @property {Enum_serviceAccountAPI_Spreadsheet_MemberType_SpreadSheet} spreadsheetId
   * The spreadsheet object of the spreadsheet containing the sheet.
   * - Required
   *
   * @property {string|number} [startIndex] 
   * The number indicating the row to start at when deleting (inclusive).
   * Range is 0 indexed, meaning it is the row # - 1;
   * - Optional
   * - ⚠️ Conflicts with row argument ⚠️
   * 
   * @property {string|number} [endIndex] 
   * The number indicating the row to stop at when deleting (exclusive).
   * Range is 0 indexed, meaning it is the row # - 1;
   * - Optional
   * - ⚠️ Conflicts with row argument ⚠️
   * 
   * @property {string|number} [row]
   * The number/string indicating the row of the range to write data.
   * Range is 0 indexed, meaning it is the row # - 1;
   * - Optional
   * - ⚠️ Conflicts with startIndex argument ⚠️
   * - ⚠️ Conflicts with endIndex argument ⚠️
  */
  /**
   * **Documentation:** 
   * - https://developers.google.com/workspace/sheets/api/reference/rest/v4/spreadsheets/batchUpdate?hl=en
   * 
   * Uses service account API to delete rows from a google sheet then caches the sheet.
   * Range is 0 indexed, meaning it is the row # - 1;
   * 
   * - **Version:** *PRE-ALPHA 1.02.03 (12/18/2025)*
   * - **File:** GS-API-OAuth2-Service-Account-GoogleSheets.gs
   * - **Section:** EDIT SHEET DATA
   * - **Member Of:** SheetServiceAPI
   *  
   * @param {Args_OAuth2_SheetServiceAPI_deleteRows} Args 
   * The config arguments for the write function
   * 
   * Required Arguments:
   * - sheet
   * - spreadsheetId
   * 
   * Optional Arguments:
   * - startIndex
   * - endIndex
   * - row
   * 
   * @return {boolean} 
   * If the API delete call succeeded.
   * 
   * @public
  */
  static deleteRows(Args) {
    let { 
      spreadsheet, 
      sheet, 
      startIndex, 
      endIndex,
      row,
    } = Args;

    // if no spreadsheet id or invalid spreadsheet id provided, warn 
    if (!instanceOfEnum(Spreadsheet, spreadsheet)) { 
      throw new Error(
        `\n` + 
        `(Service Account) Cannot attempt to delete rows of sheet;` + `\n` +
        `No spreadsheet argument provided as spreadsheet enum instance;` 
      );
    };

    // if no sheet name or invalid sheet name provided, throw error
    if (!instanceOfEnum(spreadsheet.Sheet, sheet)) { 
      throw new Error(
        `\n` + 
        `(Service Account) Cannot attempt to delete rows of sheet, from spreadsheet (${spreadsheet.id});` + `\n` +
        `No sheet argument provided as spreadsheet sheet enum instance;` 
      );
    };

    if (!row && !startIndex && !endIndex) {
      throw new Error(
        `\n` + 
        `(Service Account) Cannot attempt to delete rows of sheet ${sheet.name} from spreadsheet (${spreadsheet.id});` + `\n` +
        `No range arguments provided for deletion;` 
      );
    }
    if ((row && startIndex) || (row && endIndex)) {
      throw new Error(
        `\n` + 
        `(Service Account) Cannot attempt to delete rows of sheet ${sheet.name} from spreadsheet (${spreadsheet.id});` + `\n` +
        `Row argument cannot be passed alongside startIndex and endIndex arguments;` 
      );
    }
    if ((startIndex && !endIndex) || (!startIndex && endIndex)) {
      throw new Error(
        `\n` + 
        `(Service Account) Cannot attempt to delete rows of sheet ${sheet.name} from spreadsheet (${spreadsheet.id});` + `\n` +
        `Only one startIndex and endIndex argument provided, both arguments must be provided;` 
      );
    }
    if ((row && !startIndex) || (row && !endIndex)) {
      startIndex = row;
      endIndex = row + 1;
    }
    
    const service = this.getService();

    // ensure the service account has access
    if (!service.hasAccess()) {
      console.error(
        `\n` + 
        `(Service Account) Cannot attempt to delete rows from sheet (${sheet.name}), in range ${startIndex}:${endIndex}, from spreadsheet (${spreadsheet.id});` + `\n` + 
        `Failure to get valid access token;` 
      ); 
      return false;
    }

    const apiUrl = `https://sheets.googleapis.com/v4/spreadsheets/${spreadsheet.id}:batchUpdate`;
    
    // Construct the BatchUpdate body
    const resource = {
      requests: [
        {
          deleteDimension: {
            range: {
              sheetId: sheet.id,
              dimension: "ROWS",
              startIndex: startIndex,
              endIndex: endIndex
            }
          }
        }
      ]
    };

    const options = {
      method: 'post',
      contentType: 'application/json',
      headers: { 'Authorization': 'Bearer ' + service.getAccessToken() },
      payload: JSON.stringify(resource),
      muteHttpExceptions: true
    };

    try {
      const response = UrlFetchApp.fetch(apiUrl, options);
      if (response.getResponseCode() === 200) {
        console.log(`(Service Account) Successfully deleted rows in range ${startIndex}:${endIndex}`);

        // maybe change so all cached ranges also update
        this.cacheData({
          spreadsheetId: spreadsheet.id,
          sheetName: sheet.name
        })

        return true;
      } else {
        console.error(
          `\n` + 
          `(Service Account) Attempting to delete data from sheet (${sheet.name}), in range ${startIndex}:${endIndex}, from spreadsheet (${spreadsheet.id});` + `\n` + 
          `API delete data failure (${responseCode});` + `\n` +
          `${errorText}`
        ); 
        return false;
      }
    } catch (error) {
      console.error(
        `\n` + 
        `(Service Account) Attempting to delete data from sheet (${sheet.name}), in range ${startIndex}:${endIndex}, from spreadsheet (${spreadsheet.id});` + `\n` + 
        `URL delete data failure;` + `\n` +
        `${error.toString()}`
      );
      return false;
    }
  }
}

