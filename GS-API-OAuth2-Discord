  /**
   * **Documentation:** 
   * - https://discord.com/developers/docs/topics/oauth2
   * 
   * Will fetch the discord user instance of the requesting user.
   * - **Version:** *PRE-ALPHA 1.02.02 (12/2/2025)*
   * - **File:** GS-API-OAuth2-Discord.gs
   * - **Section:** FETCH
   * 
   * @return {object} 
   * Discord user instance.
  */
  function fetchDiscordUser_() {
    let service = getDiscordService_();
    if (!service.hasAccess()) {
      console.log(`No access. Run showAuthLink() and authorize first.`);
      return;
    }
    let url = `https://discord.com/api/users/@me`;
    let options = {
      method: `get`,
      headers: {
        Authorization: `Bearer ` + service.getAccessToken()
      },
      muteHttpExceptions: true
    };
    const response = UrlFetchApp.fetch(url, options);
    const responseCode = response.getResponseCode();

    console.log(`HTTP ${responseCode}`);
    console.log(response.getContentText());

    // parse JSON if 200
    if (responseCode == 200) {
      let user = JSON.parse(response.getContentText());
      // user will contain id, username, discriminator, avatar, and email if email scope was granted
      console.log(user);
      return user;
    } else {
      console.log(`Error: ` + response.getContentText());
      // If token expired, you can refresh via the library automatically by calling getAccessToken()
    }
  }


