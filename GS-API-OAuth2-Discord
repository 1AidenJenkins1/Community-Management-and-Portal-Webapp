  /**
   * **Documentation:** 
   * - https://discord.com/developers/docs/topics/oauth2
   * - https://github.com/googlesamples/apps-script-oauth2#1-create-the-oauth2-service
   * 
   * Gets the service for Discord.
   * - **Version:** *PRE-ALPHA 1.02.02 (12/2/2025)*
   * - **File:** GS-API-OAuth2-Discord.gs
   * - **Section:** AUTH
   * 
   * @return {OAuth2.Service} 
   * Discord service.
  */
  function getDiscordService_() {
    const discord_clientId = SCRIPT_PROPERTIES_SERVICE.getProperty("DISCORD_CLIENT_ID");
    const discord_clientSecret = SCRIPT_PROPERTIES_SERVICE.getProperty("DISCORD_CLIENT_SECRET");
    return OAuth2.createService(`discord`)
    .setAuthorizationBaseUrl(`https://discord.com/oauth2/authorize`)
    .setTokenUrl(`https://discord.com/api/oauth2/token`)
    .setClientId(discord_clientId)
    .setClientSecret(discord_clientSecret)
    .setCallbackFunction(`authCallback`)
    .setPropertyStore(PropertiesService.getUserProperties())
    .setScope(`identify email`);
  }

  /**
   * **Documentation:** 
   * - https://discord.com/developers/docs/topics/oauth2
   * 
   * Will provide a discord login link.
   * - **Version:** *PRE-ALPHA 1.02.02 (12/2/2025)*
   * - **File:** GS-API-OAuth2-Discord.gs
   * - **Section:** AUTH
  */
  function showAuthLink() {
    let service = getDiscordService_();
    if (!service.hasAccess()) {
      let authorizationUrl = service.getAuthorizationUrl();
      // show a simple HTML page with the link (open in new tab)
      let html = HtmlService.createHtmlOutput(`<a href="` + authorizationUrl + `" target="_blank">Sign in with Discord</a><p>After authorizing, close the tab and return.</p>`);
      SpreadsheetApp.getUi().showModalDialog(html, `Discord Sign-In`);
    } else {
      SpreadsheetApp.getUi().alert(`Already authorized.`);
    }
  }

  /**
   * **Documentation:** 
   * - https://discord.com/developers/docs/topics/oauth2
   * 
   * Will fetch the discord user instance of the requesting user.
   * - **Version:** *PRE-ALPHA 1.02.02 (12/2/2025)*
   * - **File:** GS-API-OAuth2-Discord.gs
   * - **Section:** AUTH
   * 
   * @return {Oauth2.service.AuthorizationUrl} 
   * Discord service auth url.
  */
  function getAuthUrl() {
    let Service = getDiscordService_();
    if (!Service.hasAccess()) {
      return Service.getAuthorizationUrl();
    }
    return null; // already logged in
  }

  /**
   * **Documentation:** 
   * 
   * Discord will redirect here after user authorizes
   * - **Version:** *PRE-ALPHA 1.02.02 (12/2/2025)*
   * - **File:** GS-API-OAuth2-Discord.gs
   * - **Section:** AUTH
   * 
   * @return {HtemlService.htmlOutput} 
   * Close window html msg.
  */
  function authCallback(request) {
    let service = getDiscordService_();
    service.handleCallback(request);

    return HtmlService.createHtmlOutput(`
      <script>
        if (window.opener) {
          window.opener.postMessage("authorized", "*");
          window.close();
        } else {
          document.body.innerText = "USPA discord login complete. Please close this window.";
        }
      </script>
    `);
  }

