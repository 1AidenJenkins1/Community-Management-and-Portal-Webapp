  /**
   * **Documentation:** 
   * - https://discord.com/developers/docs/topics/oauth2
   * 
   * Will check if the requesting user has given the discord service access.
   * Will be renamed soon.
   * - **Version:** *PRE-ALPHA 1.02.02 (12/2/2025)*
   * - **File:** GS-API-OAuth2-Discord.gs
   * - **Section:** MANAGE
   * 
   * @return {boolen} 
   * If the current user has given access.
  */
  function checkAccess() {
    let service = getDiscordService_();
    return service.hasAccess();
  }

  /**
   * **Documentation:** 
   * - https://discord.com/developers/docs/topics/oauth2
   * 
   * Will clear the stored requesting user information and token.
   * Will be renamed soon.
   * - **Version:** *PRE-ALPHA 1.02.02 (12/2/2025)*
   * - **File:** GS-API-OAuth2-Discord.gs
   * - **Section:** MANAGE
   * 
   * @return {boolen} 
   * If the current user has been reset. (always true at the moment)
  */
  function resetDiscordAuth() {
    let service = getDiscordService_();
    service.reset(); // clears stored token for the current user
    return true;
  }

