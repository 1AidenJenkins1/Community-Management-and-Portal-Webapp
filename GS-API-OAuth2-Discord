  /**
   * **Documentation:** 
   * 
   * Formats user information into a avatar url.
   * Subject to change.
   * - **Version:** *PRE-ALPHA 1.02.02 (12/2/2025)*
   * - **File:** GS-API-OAuth2-Discord.gs
   * - **Section:** DISPLAY
   * 
   * @param {string} userId 
   * The Discord user`s id.
   * 
   * @param {string} avatarId 
   * The avatar hash string from the user instance.
   * 
   * @param {number} [size=256] 
   * The desired size
   * 
   * @returns {string} 
   * The full Discord avatar URL.
  */
  function getDiscordAvatarUrl(userId, avatarId, size = 256) {
    if (!userId || !avatarId) {
      // return a default avatar URL if data is missing
      return `https://cdn.discordapp.com/embed/avatars/0.png`; 
    }

    // Check if the avatar is animated (starts with `a_`)
    const extension = avatarId.startsWith(`a_`) ? `gif` : `png`;

    // Construct the URL
    const baseUrl = `https://cdn.discordapp.com/avatars/${userId}/${avatarId}.${extension}`;

    // Append the size parameter
    return `${baseUrl}?size=${size}`;
  }

