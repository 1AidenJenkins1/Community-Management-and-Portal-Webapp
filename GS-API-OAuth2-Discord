  function getDiscordTimestamp(month, day, hour, min) {
    // Get the date and time
    const now = new Date();
    const year = now.getFullYear();
    
    const timestamp = new Date(year, month, day, hour, min);

    // to ms
    const unixTimestampMs = timestamp.getTime();

    // to seconds
    const unixTimestampSeconds = Math.floor(unixTimestampMs / 1000);

    return `<t:${unixTimestampSeconds}:R>`; // Example: long date/time format
  }

